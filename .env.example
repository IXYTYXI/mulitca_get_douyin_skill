# 飞书应用凭证（在 https://open.feishu.cn 创建企业自建应用后获取）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 飞书多维表格配置（从浏览器地址栏获取）
# URL 格式: https://xxx.feishu.cn/base/{APP_TOKEN}?table={TABLE_ID}
FEISHU_APP_TOKEN=your_bitable_app_token
FEISHU_TABLE_ID=your_table_id

# scrape_all.py 用到的表 ID（在飞书多维表格中创建三张表后填入）
VIDEO_TABLE_ID=your_video_table_id
IMAGE_TABLE_ID=your_image_table_id
COMMENT_TABLE_ID=your_comment_table_id

# 搜索关键词
DOUYIN_KEYWORD=your_keyword

# 抖音 Cookie（登录后从浏览器开发者工具复制）
DOUYIN_COOKIE=

# 代理设置（可选）
# PROXY_URL=http://127.0.0.1:7890

# 爬取配置
MAX_PAGES=10
REQUEST_DELAY=2

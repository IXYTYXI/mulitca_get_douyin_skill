# 飞书应用凭证（在 https://open.feishu.cn 创建企业自建应用后获取）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 飞书多维表格配置（从浏览器地址栏获取）
# URL 格式: https://xxx.feishu.cn/base/{APP_TOKEN}?table={TABLE_ID}
FEISHU_APP_TOKEN=your_bitable_app_token
FEISHU_TABLE_ID=your_table_id

# scrape_all.py 用到的表 ID —— 标准 4 张表（可用 `python main.py scrape-to-bitable ... --structure-only` 一键创建）
VIDEO_TABLE_ID=your_video_table_id          # 视频作品
IMAGE_TABLE_ID=your_image_table_id          # 图文作品
COMMENT_L1_TABLE_ID=your_comment_l1_table_id   # 一级评论
COMMENT_L2_TABLE_ID=your_comment_l2_table_id   # 二级评论
# 兼容旧变量名（等价于 COMMENT_L1_TABLE_ID）
# COMMENT_TABLE_ID=your_comment_l1_table_id

# 搜索关键词
DOUYIN_KEYWORD=your_keyword

# 抖音 Cookie（本项目爬取的是【抖音】，不是小红书；这里不需要小红书的 web_session / a1 字段）
# 两种设置方式，二选一：
#   1) 推荐：运行 `python main.py login` 打开浏览器扫码登录，程序会自动把 Cookie 写入
#      本文件的 DOUYIN_COOKIE 和 cookies.json（cookies.json 存在时优先于此变量）。
#   2) 手动：登录 douyin.com 后，在浏览器开发者工具 Network 里任选一个 www.douyin.com
#      请求，复制其请求头里的整条 Cookie（单行，形如 `name1=value1; name2=value2; ...`）粘到下面。
# 必须是【已登录】状态的 Cookie，关键字段应包含：
#   sessionid / sessionid_ss、sid_guard、uid_tt / uid_tt_ss、ttwid、msToken、odin_tt、
#   passport_csrf_token、s_v_web_id。（登录检测依据：sessionid/sessionid_ss 且 sid_guard 或 uid_tt）
# Cookie 会过期，爬虫开始返回空结果时请重新登录获取。
DOUYIN_COOKIE=

# 代理设置（可选）
# PROXY_URL=http://127.0.0.1:7890

# 爬取配置
MAX_PAGES=10
REQUEST_DELAY=2

# 限流 / 节流策略（抖音对高频或固定节奏的请求会临时返回空结果）
# 遇到频繁空结果时，调大 REQUEST_DELAY / REQUEST_JITTER / EMPTY_RETRY
REQUEST_JITTER=0.4        # 每次请求延时的随机抖动幅度（±40% × REQUEST_DELAY）
REQUEST_MAX_RETRIES=3     # 网络/传输错误的重试次数
EMPTY_RETRY=2            # 空/被风控页面的退避重试次数
BACKOFF_FACTOR=2.0       # 重试退避的指数增长系数
BACKOFF_MAX=30          # 单次退避上限（秒）
